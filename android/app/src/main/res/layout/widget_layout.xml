<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Business Analytics"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <ViewFlipper
        android:id="@+id/widget_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:inAnimation="@anim/widget_slide_in_bottom"
        android:outAnimation="@anim/widget_slide_out_top"
        android:flipInterval="5000"
        android:autoStart="true">

        <TextView
            android:id="@+id/widget_message_1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="No recent insights"
            android:textStyle="bold"
            android:textColor="#333333"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="32sp"
            android:autoSizeStepGranularity="2sp" />

        <TextView
            android:id="@+id/widget_message_2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="No recent insights"
            android:textStyle="bold"
            android:textColor="#333333"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="32sp"
            android:autoSizeStepGranularity="2sp" />

    </ViewFlipper>

</LinearLayout>
